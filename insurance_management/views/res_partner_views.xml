<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Extend Partner Form View -->
        <record id="view_partner_form_insurance" model="ir.ui.view">
            <field name="name">res.partner.form.insurance</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_insurance_policies"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                            invisible="insurance_policy_count == 0">
                        <field name="insurance_policy_count" widget="statinfo" string="Policies"/>
                    </button>
                    <button name="action_view_insurance_claims"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exclamation-circle"
                            invisible="insurance_claim_count == 0">
                        <field name="insurance_claim_count" widget="statinfo" string="Claims"/>
                    </button>
                </xpath>
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="is_insurance_customer"/>
                </xpath>
            </field>
        </record>

        <!-- Insurance Customers Action -->
        <record id="action_insurance_customers" model="ir.actions.act_window">
            <field name="name">Insurance Customers</field>
            <field name="res_model">res.partner</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('insurance_policy_count', '>', 0)]</field>
            <field name="context">{'default_is_insurance_customer': True}</field>
        </record>
    </data>
</odoo>
