<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Policy Form View -->
        <record id="view_insurance_policy_form" model="ir.ui.view">
            <field name="name">insurance.policy.form</field>
            <field name="model">insurance.policy</field>
            <field name="arch" type="xml">
                <form string="Insurance Policy">
                    <header>
                        <button name="action_confirm"
                                string="Confirm"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_running"
                                string="Set Running"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'confirmed'"/>
                        <button name="action_expire"
                                string="Mark Expired"
                                type="object"
                                invisible="state not in ['running', 'confirmed']"/>
                        <button name="action_renew"
                                string="Renew Policy"
                                type="object"
                                invisible="state not in ['expired', 'running']"/>
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                invisible="state in ['cancelled', 'expired']"/>
                        <button name="action_create_invoice"
                                string="Create Invoice"
                                type="object"
                                invisible="state not in ['confirmed', 'running']"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,confirmed,running,expired,cancelled"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_claims"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-exclamation-circle"
                                    invisible="claim_count == 0">
                                <field name="claim_count" widget="statinfo" string="Claims"/>
                            </button>
                            <button name="action_view_invoices"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-usd"
                                    invisible="invoice_count == 0">
                                <field name="invoice_count" widget="statinfo" string="Invoices"/>
                            </button>
                        </div>
                        <group>
                            <group string="Policy Information">
                                <field name="name"/>
                                <field name="reference" readonly="1"/>
                                <field name="category_id"/>
                                <field name="sub_category_id"
                                       domain="[('parent_id', '=', category_id)]"/>
                                <field name="policy_term_id"/>
                                <field name="payment_type"/>
                            </group>
                            <group string="Parties">
                                <field name="partner_id"/>
                                <field name="agent_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="currency_id" groups="base.group_multi_currency"/>
                                <field name="premium_amount"/>
                            </group>
                        </group>
                        <group>
                            <group string="Policy Period">
                                <field name="issue_date"/>
                                <field name="expiry_date"/>
                                <field name="duration"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Insured Person">
                                <group>
                                    <group>
                                        <field name="insured_name"/>
                                        <field name="insured_dob"/>
                                        <field name="insured_gender"/>
                                    </group>
                                    <group>
                                        <field name="insured_phone"/>
                                        <field name="insured_email"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Nominees">
                                <field name="nominee_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="relationship"/>
                                        <field name="age"/>
                                        <field name="percentage"/>
                                        <field name="phone"/>
                                        <field name="email"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Documents">
                                <field name="document_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="document_type"/>
                                        <field name="state"/>
                                        <field name="note"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                            <page string="Terms &amp; Conditions">
                                <field name="terms_conditions"/>
                            </page>
                            <page string="Notes">
                                <field name="note"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Policy List View -->
        <record id="view_insurance_policy_list" model="ir.ui.view">
            <field name="name">insurance.policy.list</field>
            <field name="model">insurance.policy</field>
            <field name="arch" type="xml">
                <list string="Insurance Policies" decoration-success="state == 'running'" decoration-muted="state in ['expired','cancelled']" decoration-warning="state == 'confirmed'">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="category_id"/>
                    <field name="partner_id"/>
                    <field name="agent_id"/>
                    <field name="premium_amount"/>
                    <field name="currency_id" groups="base.group_multi_currency"/>
                    <field name="issue_date"/>
                    <field name="expiry_date"/>
                    <field name="claim_count"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Policy Kanban View -->
        <record id="view_insurance_policy_kanban" model="ir.ui.view">
            <field name="name">insurance.policy.kanban</field>
            <field name="model">insurance.policy</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="category_id"/>
                    <field name="partner_id"/>
                    <field name="premium_amount"/>
                    <field name="currency_id"/>
                    <field name="state"/>
                    <field name="expiry_date"/>
                    <field name="claim_count"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle">
                                    <field name="reference"/>
                                </div>
                                <div>
                                    <span>Category: </span><field name="category_id"/>
                                </div>
                                <div>
                                    <span>Policyholder: </span><field name="partner_id"/>
                                </div>
                                <div>
                                    <span>Premium: </span>
                                    <field name="premium_amount" widget="monetary"/>
                                </div>
                                <div>
                                    <span>Expiry: </span><field name="expiry_date"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Policy Search View -->
        <record id="view_insurance_policy_search" model="ir.ui.view">
            <field name="name">insurance.policy.search</field>
            <field name="model">insurance.policy</field>
            <field name="arch" type="xml">
                <search string="Insurance Policies">
                    <field name="name"/>
                    <field name="reference"/>
                    <field name="partner_id"/>
                    <field name="category_id"/>
                    <field name="agent_id"/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                    <filter string="Expired" name="expired" domain="[('state', '=', 'expired')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancelled')]"/>
                    <group>
                        <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                        <filter string="Agent" name="group_by_agent" context="{'group_by': 'agent_id'}"/>
                        <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Issue Date" name="group_by_issue_date" context="{'group_by': 'issue_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Policy Actions -->
        <record id="action_insurance_policy" model="ir.actions.act_window">
            <field name="name">All Policies</field>
            <field name="res_model">insurance.policy</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

        <record id="action_insurance_policy_kanban" model="ir.actions.act_window">
            <field name="name">Insurance Dashboard</field>
            <field name="res_model">insurance.policy</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

        <record id="action_insurance_my_policy" model="ir.actions.act_window">
            <field name="name">My Policies</field>
            <field name="res_model">insurance.policy</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="domain">[('create_uid', '=', uid)]</field>
        </record>
    </data>
</odoo>
