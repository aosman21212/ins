<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Category List View -->
        <record id="view_insurance_category_list" model="ir.ui.view">
            <field name="name">insurance.category.list</field>
            <field name="model">insurance.category</field>
            <field name="arch" type="xml">
                <list string="Insurance Categories">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="parent_id"/>
                    <field name="policy_count"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Category Form View -->
        <record id="view_insurance_category_form" model="ir.ui.view">
            <field name="name">insurance.category.form</field>
            <field name="model">insurance.category</field>
            <field name="arch" type="xml">
                <form string="Insurance Category">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_policies"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o">
                                <field name="policy_count" widget="statinfo" string="Policies"/>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="code"/>
                                <field name="parent_id" domain="[('parent_id', '=', False)]"/>
                            </group>
                            <group>
                                <field name="color" widget="color_picker"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description"/>
                            </page>
                            <page string="Sub-categories">
                                <field name="child_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="policy_count"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Category Search View -->
        <record id="view_insurance_category_search" model="ir.ui.view">
            <field name="name">insurance.category.search</field>
            <field name="model">insurance.category</field>
            <field name="arch" type="xml">
                <search string="Insurance Categories">
                    <field name="name" string="Name"/>
                    <field name="code" string="Code"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Top-level" name="top_level" domain="[('parent_id', '=', False)]"/>
                    <filter string="Sub-categories" name="subcategories" domain="[('parent_id', '!=', False)]"/>
                    <group>
                        <filter string="Parent Category" name="group_by_parent" context="{'group_by': 'parent_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Category Action -->
        <record id="action_insurance_category" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">insurance.category</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('parent_id', '=', False)]</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>

        <!-- Sub-category Action -->
        <record id="action_insurance_subcategory" model="ir.actions.act_window">
            <field name="name">Sub-categories</field>
            <field name="res_model">insurance.category</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('parent_id', '!=', False)]</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>
    </data>
</odoo>
