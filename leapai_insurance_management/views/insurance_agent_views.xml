<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Agent List View -->
        <record id="view_insurance_agent_list" model="ir.ui.view">
            <field name="name">insurance.agent.list</field>
            <field name="model">insurance.agent</field>
            <field name="arch" type="xml">
                <list string="Insurance Agents">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="commission_rate"/>
                    <field name="policy_count"/>
                    <field name="commission_total"/>
                    <field name="currency_id" groups="base.group_multi_currency"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- Agent Form View -->
        <record id="view_insurance_agent_form" model="ir.ui.view">
            <field name="name">insurance.agent.form</field>
            <field name="model">insurance.agent</field>
            <field name="arch" type="xml">
                <form string="Insurance Agent">
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_policies"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-file-text-o">
                                <field name="policy_count" widget="statinfo" string="Policies"/>
                            </button>
                        </div>
                        <group>
                            <group string="Agent Information">
                                <field name="name"/>
                                <field name="code"/>
                                <field name="partner_id"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </group>
                            <group string="Commission">
                                <field name="commission_rate"/>
                                <field name="currency_id" groups="base.group_multi_currency"/>
                                <field name="commission_total"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Notes">
                                <field name="note"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Agent Search View -->
        <record id="view_insurance_agent_search" model="ir.ui.view">
            <field name="name">insurance.agent.search</field>
            <field name="model">insurance.agent</field>
            <field name="arch" type="xml">
                <search string="Insurance Agents">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="email"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                </search>
            </field>
        </record>

        <!-- Agent Action -->
        <record id="action_insurance_agent" model="ir.actions.act_window">
            <field name="name">Agents</field>
            <field name="res_model">insurance.agent</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>
    </data>
</odoo>
